{
    "version": 2,
    "configurePresets": [
        {
            "name": "ninja-base",
            "displayName": "Visual Studio 2022 (base)",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build-vs2022",
            "architecture": "x64",
            "environment": {
                "VCPKG_DOWNLOADS": "${sourceDir}/.vcpkg/downloads",
                "VCPKG_DEFAULT_BINARY_CACHE": "${sourceDir}/.vcpkg/bincache"
            },
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "ninja-debug",
            "displayName": "Visual Studio 2022 Debug",
            "inherits": "ninja-base"
        },
        {
            "name": "ninja-release",
            "displayName": "Visual Studio 2022 Release",
            "inherits": "ninja-base"
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "description": "",
            "displayName": "",
            "configurePreset": "ninja-debug",
            "configuration": "Debug"
        }
    ]
}
